# Supabase PostgreSQL (use transaction pooler for Vercel serverless)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?pgbouncer=true"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# FastAPI ML service (Railway or local)
ML_API_URL="http://localhost:8000"
