{
  "name": "weedsense",
  "private": true,
  "workspaces": [
    "frontend",
    "database"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && PYTHONPATH=. .venv/bin/uvicorn api.main:app --reload --host 127.0.0.1 --port 8000",
    "build": "npm run build --workspace=frontend",
    "db:generate": "npm run generate --workspace=database",
    "db:migrate": "npm run migrate --workspace=database",
    "db:seed": "npm run seed --workspace=database",
    "db:push": "npm run push --workspace=database"
  }
}
